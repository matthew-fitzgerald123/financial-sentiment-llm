FROM nvidia/cuda:12.1.0-runtime-ubuntu22.04

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends python3 python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Install vLLM and FastAPI serving dependencies
COPY app/requirements-vllm.txt .
RUN pip3 install --no-cache-dir -r requirements-vllm.txt

# Copy application code and adapter weights
COPY app/ ./app/
COPY mistral-finetuned/ ./mistral-finetuned/

ENV BASE_MODEL_ID=mistralai/Mistral-7B-Instruct-v0.3
ENV ADAPTER_PATH=./mistral-finetuned
ENV MODEL_VERSION=mistral-7b-finance-mlx-lora-v1

EXPOSE 8080

CMD ["uvicorn", "app.main_vllm:app", "--host", "0.0.0.0", "--port", "8080"]
